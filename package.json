{
  "name": "repopeek",
  "version": "1.1.0",
  "description": "Beautiful GitHub repository information CLI built with Ink.",
  "type": "module",
  "bin": {
    "repopeek": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "github",
    "cli",
    "ink",
    "terminal",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^18.3.12",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
